<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>XTRA — Kleurrijke Aap · AiCandy</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{--y:#FFE600;--bg:#0A0A0A;--w:#fff;--w60:rgba(255,255,255,.6);--w35:rgba(255,255,255,.35);--w15:rgba(255,255,255,.15)}
  html,body{font-family:'Inter',system-ui,sans-serif;background:#000;overflow:hidden;height:100vh;width:100vw;cursor:none}

  .cursor{position:fixed;width:10px;height:10px;background:var(--y);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s,height .18s}
  .cursor.big{width:32px;height:32px;background:transparent;border:2px solid var(--y)}

  #deck{position:relative;width:100vw;height:100vh}
  .slide{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:5vh 9vw 4.5rem;opacity:0;pointer-events:none;transition:opacity .5s cubic-bezier(.4,0,.2,1);overflow:hidden}
  .slide.active{opacity:1;pointer-events:all}
  .bg-dark{background:var(--bg)}
  .bg-light{background:#f2f2f2}

  .r{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;width:100%;display:flex;flex-direction:column;align-items:center}
  .active .r{opacity:1;transform:translateY(0)}
  .active .r:nth-child(1){transition-delay:.1s}
  .active .r:nth-child(2){transition-delay:.23s}
  .active .r:nth-child(3){transition-delay:.36s}
  .active .r:nth-child(4){transition-delay:.49s}
  .active .r:nth-child(5){transition-delay:.62s}
  .g1{margin-top:.6rem}.g2{margin-top:1.2rem}.g3{margin-top:2rem}.g4{margin-top:3rem}

  /* ── Images on dark slides ── */
  .ape-img{
    width:auto;
    max-width:min(640px,76vw);
    max-height:42vh;
    object-fit:contain;
    border-radius:12px;
    display:block;
  }
  .ape-gif{border-radius:10px;max-height:38vh}

  /* ── pluizig on light slide — no border radius, blends into bg ── */
  .ape-img-light{
    width:auto;
    max-width:min(480px,60vw);
    max-height:46vh;
    object-fit:contain;
    display:block;
  }

  /* ── logos ── */
  .xtra-logo{height:clamp(70px,10vw,130px);width:auto;display:block}
  .aicandy-logo{height:clamp(50px,10vw,120px);width:auto}

  /* ── type ── */
  .eyebrow{font-size:clamp(.58rem,.9vw,.74rem);font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--y)}
  .eyebrow.dark{color:#888}
  h2{font-size:clamp(1.3rem,2.5vw,2.3rem);font-weight:900;line-height:1.15;text-align:center;max-width:24ch;color:var(--w);text-wrap:balance}
  .dark-h{color:#111}
  .ch{font-size:clamp(1.8rem,4vw,3.8rem)}
  p{font-size:clamp(.76rem,1.2vw,.98rem);line-height:1.8;text-align:center;max-width:64ch;color:var(--w60);text-wrap:balance}
  .y{color:var(--y)}.dim{color:var(--w35)}
  .sc{font-size:.65rem;letter-spacing:.22em;text-transform:uppercase}
  .tl{font-size:clamp(1.2rem,2.8vw,2.6rem);font-weight:900;color:var(--y);text-align:center;line-height:1.2;font-style:italic;text-wrap:balance}
  .bar{width:36px;height:3px;background:var(--y);border-radius:2px;margin:1.3rem auto 0}

  /* ── cards ── */
  .card-row{display:flex;gap:1px;justify-content:center;align-items:stretch;width:100%;max-width:860px}
  .card{flex:1 1 0;background:rgba(255,255,255,.04);border:1px solid var(--w15);padding:1.6rem 1.4rem;display:flex;flex-direction:column;gap:.6rem}
  .card:first-child{border-radius:12px 0 0 12px}.card:last-child{border-radius:0 12px 12px 0}
  .card-num{font-size:clamp(.55rem,.82vw,.7rem);font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--y)}
  .card h3{font-size:clamp(.88rem,1.4vw,1.1rem);font-weight:800;line-height:1.2;color:var(--w);text-align:left}
  .card p{font-size:clamp(.68rem,.98vw,.82rem);color:var(--w60);line-height:1.6;text-align:left;max-width:none;text-wrap:balance}

  /* ── scen list ── */
  .scen-list{width:100%;max-width:680px;display:flex;flex-direction:column;gap:.6rem}
  .scen{border-left:3px solid var(--y);padding:.9rem 1.2rem;background:rgba(255,255,255,.035);border-radius:0 8px 8px 0}
  .scen p{text-align:left;max-width:none;font-size:clamp(.72rem,1.1vw,.9rem);line-height:1.65}
  .scen .q{color:var(--y);font-style:italic}

  /* ── wordplay ── */
  .wp{font-size:clamp(1.2rem,2.6vw,2.3rem);font-weight:900;color:var(--w);font-style:italic;text-align:center;line-height:1.25}
  .wp .hl{color:var(--y);text-decoration:underline;text-decoration-color:rgba(255,230,0,.35);text-underline-offset:5px}

  /* ── pills ── */
  .pill-row{display:flex;gap:.55rem;flex-wrap:wrap;justify-content:center}
  .pill{border:1.5px solid var(--y);color:var(--y);font-weight:700;font-size:clamp(.68rem,1vw,.84rem);padding:.32rem 1rem;border-radius:100px}

  /* ── hbox ── */
  .hbox{background:rgba(255,230,0,.07);border:1px solid rgba(255,230,0,.22);border-radius:10px;padding:.9rem 1.4rem;max-width:640px;width:100%}
  .hbox p{font-size:clamp(.72rem,1.1vw,.9rem);color:var(--y);font-style:italic}

  /* ── tech ── */
  .tech-row{display:flex;gap:1px;width:100%;max-width:820px}
  .tech{flex:1 1 0;background:rgba(255,255,255,.04);border:1px solid var(--w15);padding:1.4rem 1.3rem;display:flex;flex-direction:column;gap:.5rem}
  .tech:first-child{border-radius:12px 0 0 12px}.tech:last-child{border-radius:0 12px 12px 0}
  .tech-label{font-size:clamp(.55rem,.8vw,.7rem);font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:var(--y)}
  .tech h4{font-size:clamp(.82rem,1.3vw,1rem);font-weight:800;color:var(--w);line-height:1.2}
  .tech p{font-size:clamp(.65rem,.95vw,.8rem);color:var(--w60);line-height:1.55;text-align:left;max-width:none}

  /* ── footer brand ── */
  .brand{position:fixed;bottom:1.4rem;left:50%;transform:translateX(-50%);opacity:.85;z-index:100;pointer-events:none;background:rgba(0,0,0,.55);padding:.3rem .9rem;border-radius:100px}
  .brand img{height:22px;width:auto}

  /* ── progress ── */
  #pb{position:fixed;bottom:0;left:0;height:3px;background:var(--y);z-index:200;transition:width .4s ease;pointer-events:none}

  /* ── nav ── */
  #nav{position:fixed;bottom:1.3rem;right:1.8rem;display:flex;align-items:center;gap:.7rem;z-index:300}
  #cnt{font-size:.68rem;font-weight:700;color:var(--w35);letter-spacing:.1em;min-width:3.5em;text-align:right;font-variant-numeric:tabular-nums}
  .nb{width:34px;height:34px;border-radius:50%;border:1.5px solid var(--w15);background:rgba(255,255,255,.05);color:var(--w35);display:flex;align-items:center;justify-content:center;cursor:none;font-size:.85rem;transition:background .2s,border-color .2s,color .2s}
  .nb:hover{background:var(--y);border-color:var(--y);color:var(--bg)}
  /* nav on light slides */
  #nav.on-light #cnt{color:rgba(0,0,0,.4)}
  #nav.on-light .nb{border-color:rgba(0,0,0,.18);background:rgba(0,0,0,.06);color:rgba(0,0,0,.4)}
  #nav.on-light .nb:hover{background:var(--bg);border-color:var(--bg);color:var(--y)}
  /* brand on light slides */
  .brand.on-light{background:rgba(0,0,0,.7)}
</style>
</head>
