<script>
const IMGS={
  XTRA:    "data:image/png;base64,",
  AICANDY: "data:image/png;base64,",
  PLUIZIG: "data:image/png;base64,",
  HANDAAP: "data:image/png;base64,",
  WALKING: "data:image/png;base64,",
  EEE:     "data:image/gif;base64,"
};
document.querySelectorAll('[data-src]').forEach(el=>{el.src=IMGS[el.dataset.src];el.removeAttribute('data-src')});

const curEl=document.getElementById('cur');
document.addEventListener('mousemove',e=>{curEl.style.left=e.clientX+'px';curEl.style.top=e.clientY+'px'});
document.querySelectorAll('.nb').forEach(b=>{
  b.addEventListener('mouseenter',()=>curEl.classList.add('big'));
  b.addEventListener('mouseleave',()=>curEl.classList.remove('big'));
});

const slides=[...document.querySelectorAll('.slide')];
const pb=document.getElementById('pb');
const cntEl=document.getElementById('cnt');
const navEl=document.getElementById('nav');
const brandEl=document.getElementById('brand');
const N=21;
let cur=0;

function goTo(i){
  if(i<0||i>=N)return;
  slides[cur].classList.remove('active');
  cur=i;
  slides[cur].classList.add('active');
  cntEl.textContent=`${cur+1} / ${N}`;
  pb.style.width=`${((cur+1)/N)*100}%`;
  const light=slides[cur].classList.contains('bg-light');
  navEl.classList.toggle('on-light',light);
  brandEl.classList.toggle('on-light',light);
}
function go(d){goTo(cur+d)}

document.getElementById('prev').addEventListener('click',()=>go(-1));
document.getElementById('next').addEventListener('click',()=>go(1));
document.addEventListener('keydown',e=>{
  if(['ArrowRight','ArrowDown',' '].includes(e.key)){e.preventDefault();go(1)}
  if(['ArrowLeft','ArrowUp'].includes(e.key)){e.preventDefault();go(-1)}
});
let tx=0;
document.addEventListener('touchstart',e=>{tx=e.touches[0].clientX},{passive:true});
document.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx;if(Math.abs(dx)>40)go(dx<0?1:-1)});
document.getElementById('deck').addEventListener('click',e=>{if(e.target.closest('.nb'))return;go(e.clientX>window.innerWidth/2?1:-1)});
</script>
</body>
</html>
